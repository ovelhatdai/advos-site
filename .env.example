# Variáveis do endpoint de captura de lead (functions/api/lead.js).
# No Cloudflare Pages, defina-as em Settings > Environment variables (não comite o .env real).

# Resend — envio do e-mail de notificação de cada lead novo
RESEND_API_KEY=re_xxxxxxxxxxxxxxxx
LEAD_FROM_EMAIL=site@advos.ai          # remetente; o domínio precisa estar verificado no Resend
LEAD_NOTIFY_EMAIL=vendas@advos.ai      # caixa que recebe a notificação de lead

# Mautic (opcional) — automação/nutrição. URL de submit do formulário do Mautic.
# Ex.: https://SEU-MAUTIC/form/submit?formId=1
MAUTIC_FORM_URL=

# (Opcional) também criar o lead direto no Base44 (mesmo schema de Lead)
BASE44_APP_ID=
BASE44_API_KEY=
