---
import Base from '../layouts/Base.astro';

const { comp, title, description, canonical, intro, tldr, criteria, whenComp, whenAdvos, faqs, demo } = Astro.props;

const FAQ = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })),
};
const BREADCRUMB = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Advogando OS', item: 'https://advos.ai/' },
    { '@type': 'ListItem', position: 2, name: `Advogando OS vs ${comp}`, item: canonical },
  ],
};
---

<Base title={title} description={description} canonical={canonical}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(FAQ)} />
    <script type="application/ld+json" set:html={JSON.stringify(BREADCRUMB)} />
  </Fragment>

  <section class="hero" style="padding:64px 0 36px">
    <div class="container">
      <span class="eyebrow">Comparativo</span>
      <h1>Advogando OS <span class="grad">vs {comp}</span></h1>
      <p class="sub" set:html={intro}></p>
      <div class="hero-cta">
        <a href="/#testar" class="btn btn-primary">Testar 7 dias grátis →</a>
        <a href="/#recursos" class="btn btn-ghost">Ver recursos</a>
      </div>
    </div>
  </section>

  <section style="padding-top:0">
    <div class="container">
      <div class="card" style="max-width:760px">
        <span class="eyebrow">Resumo rápido</span>
        <ul>{tldr.map((t) => <li set:html={t}></li>)}</ul>
      </div>
    </div>
  </section>

  <section>
    <div class="container">
      <h2>Comparativo lado a lado</h2>
      <table class="cmp">
        <thead><tr><th>Critério</th><th>Advogando OS</th><th>{comp}</th></tr></thead>
        <tbody>{criteria.map((r) => <tr><td>{r.c}</td><td set:html={r.advos}></td><td set:html={r.comp}></td></tr>)}</tbody>
      </table>
      <p class="note">Os dados do concorrente refletem informações e relatos públicos (incl. Reclame Aqui); podem variar — confirme diretamente com o fornecedor.</p>
    </div>
  </section>

  <section>
    <div class="container">
      <div class="feature-row">
        <div class="txt">
          <span class="tag">Quando o {comp} faz sentido</span>
          <h3>Onde o {comp} pode ser a melhor escolha</h3>
          <p set:html={whenComp}></p>
        </div>
        <div class="txt">
          <span class="tag">Quando é o Advogando OS</span>
          <h3>Onde o Advogando OS ganha</h3>
          <p set:html={whenAdvos}></p>
        </div>
      </div>
    </div>
  </section>

  {demo && (
    <section style="padding-top:0">
      <div class="container">
        <div class="mockup" style="max-width:960px;margin:0 auto">
          <div class="bar"><i></i><i></i><i></i><span class="url">app.advos.ai</span></div>
          <img src={demo.src} width="1600" height="900" loading="lazy" alt={demo.alt} />
        </div>
      </div>
    </section>
  )}

  <section id="faq">
    <div class="container">
      <span class="eyebrow">Dúvidas</span>
      <h2>Perguntas frequentes</h2>
      <div class="faq" style="margin-top:18px;max-width:820px">
        {faqs.map((f) => <details><summary>{f.q}</summary><p>{f.a}</p></details>)}
      </div>
    </div>
  </section>

  <section id="testar">
    <div class="container" style="text-align:center">
      <h2>Veja o Advogando OS na prática</h2>
      <p>Teste 7 dias grátis e compare você mesmo — com IA, WhatsApp oficial e boletos no mesmo sistema.</p>
      <div style="margin-top:18px"><a href="/#testar" class="btn btn-primary">Começar agora →</a></div>
    </div>
  </section>
</Base>
