---
import body from '../content/landing-body.html?raw';
import style from '../content/landing-style.css?raw';

const title = 'Advogando OS — a IA que fecha o contrato e o sistema que toca o processo';
const description =
  'Sistema jurídico com IA: a Clara Converte atende no WhatsApp oficial e fecha o contrato; o processo roda no mesmo sistema (petição por IA, boletos, automação). Você comanda por MCP via Codex e Claude Code. Multi-área. Teste 7 dias.';

const faqs = [
  { q: 'O número do WhatsApp toma ban?', a: 'Não. O ADVOS usa o WhatsApp API Oficial da Meta, homologado para uso comercial. É o oposto da automação de WhatsApp Web em número pessoal, que é o que toma bloqueio. Número oficial, estável, sem risco de "comportamento de robô".' },
  { q: 'A IA realmente fecha o contrato, ou só responde mensagem?', a: 'Fecha. A Clara Converte qualifica o lead, conduz a negociação dentro das regras que você definir, gera o contrato e envia para assinatura eletrônica (ZapSign). Contrato assinado vira cliente e abre o processo automaticamente. Ela atua como SDR e closer, não como FAQ.' },
  { q: 'Como funciona a integração com Codex e Claude Code?', a: 'O ADVOS expõe suas operações via MCP (Model Context Protocol). Conectado o Codex ou o Claude Code, você pede em linguagem natural e a IA executa dentro do sistema — sem abrir tela por tela e sem precisar de um desenvolvedor para cada automação.' },
  { q: 'O cliente consegue acompanhar o processo sem ligar pro escritório?', a: 'Sim. O andamento fica disponível pelo próprio WhatsApp, no mesmo canal do atendimento. O cliente pergunta como está o processo e recebe a fase atual — sem app separado, sem portal solto.' },
  { q: 'Vocês atendem minha área do Direito?', a: 'O ADVOS é multi-área: previdenciário, trabalhista, cível, família, tributário e demais áreas do contencioso e administrativo. No previdenciário há extras: credenciais do Meu INSS criptografadas e vídeo de confirmação do cliente.' },
  { q: 'Preciso de outra ferramenta para emitir boleto e conciliar pagamento?', a: 'Não. Emissão de boleto e conciliação de pagamento são nativas. O pagamento casa com o contrato automaticamente, dentro do sistema — sem gateway à parte e sem planilha.' },
  { q: 'A IA escreve a petição mesmo, ou só me dá um modelo?', a: 'Escreve. Réplica, contestação e recursos saem em rascunho redigido pela IA, prontos para a sua revisão. Não é busca em banco de modelos — é a peça redigida para o seu caso.' },
  { q: 'O teste grátis é completo?', a: 'São 7 dias com cartão, com acesso à Clara Converte, ao WhatsApp oficial e à esteira completa. Você experimenta o sistema fechando contrato, não uma versão capada.' },
  { q: 'Recebo muitos leads no WhatsApp e não dou conta de responder. Como o ADVOS resolve?', a: 'Com o WhatsApp API oficial em coexistência, você dispara follow-up para centenas ou milhares de leads de uma vez — sem perder o WhatsApp normal no seu celular. Você pagou pelo lead; o ADVOS garante que ele seja respondido. Coexistência é o melhor dos dois mundos: API oficial para escala e o seu número no celular para conversar.' },
  { q: 'Vocês integram com o INSS administrativo, não só o judicial?', a: 'Sim, e isso é único no mercado. Todos os sistemas integram só pelo número CNJ (processo judicial). O ADVOS integra também o processo administrativo do INSS — antes de virar judicial, quando ainda não há CNJ — mapeia e vincula ao seu cliente. Quando o caso vira judicial, seguimos pelo CNJ também.' },
  { q: 'O cliente é avisado da perícia?', a: 'Sim. O ADVOS dispara avisos de perícia agendados pelo WhatsApp, automaticamente. O cliente recebe o aviso, acompanha o andamento do processo e fala com o escritório no mesmo canal — 24 horas por dia, 7 dias por semana, num sistema só, sem contratar outras ferramentas.' },
];

const ORG = {
  '@context': 'https://schema.org', '@type': 'Organization', name: 'Advogando OS', alternateName: 'ADVOS',
  url: 'https://advos.ai', logo: 'https://advos.ai/favicon.svg',
  description: 'Sistema jurídico com IA que fecha contrato no WhatsApp oficial e toca o processo do escritório.',
};
const SW = {
  '@context': 'https://schema.org', '@type': 'SoftwareApplication', name: 'Advogando OS', alternateName: 'ADVOS',
  applicationCategory: 'BusinessApplication', operatingSystem: 'Web', inLanguage: 'pt-BR', url: 'https://advos.ai',
  description: 'Sistema de gestão jurídica com IA que atende e fecha contrato no WhatsApp oficial, redige petições, emite boletos e automatiza a rotina; operável por MCP via Codex e Claude Code.',
  featureList: ['Agente de IA que fecha contrato no WhatsApp', 'WhatsApp API oficial da Meta', 'Acompanhamento do processo pelo cliente', 'Petição redigida por IA', 'Boletos e conciliação nativos', 'Automação de estágios', 'Operação agêntica via MCP (Codex e Claude Code)'],
  offers: {
    '@type': 'AggregateOffer', priceCurrency: 'BRL', lowPrice: '500', highPrice: '2000', offerCount: '4',
    offers: [500, 1000, 1500, 2000].map((p) => ({ '@type': 'Offer', priceCurrency: 'BRL', price: String(p), priceSpecification: { '@type': 'UnitPriceSpecification', price: String(p), priceCurrency: 'BRL', unitText: 'mês' } })),
  },
};
const FAQ = { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faqs.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) };
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href="https://advos.ai/" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Advogando OS" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content="https://advos.ai/" />
    <meta property="og:image" content="https://advos.ai/og.png" />
    <meta property="og:locale" content="pt_BR" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://advos.ai/og.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter+Tight:wght@500;600;700&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet" />
    <style is:inline set:html={style}></style>
    <script type="application/ld+json" is:inline set:html={JSON.stringify(ORG)} />
    <script type="application/ld+json" is:inline set:html={JSON.stringify(SW)} />
    <script type="application/ld+json" is:inline set:html={JSON.stringify(FAQ)} />
  </head>
  <body>
    <Fragment set:html={body} />
  </body>
</html>
